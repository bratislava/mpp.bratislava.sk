{
  "name": "mpp-backend",
  "version": "0.0.1",
  "description": "NestJS MPP Backend",
  "author": "Bratislava Innovations",
  "private": true,
  "license": "EUPL-1.2",
  "type": "module",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main.js",
    "start:migrate:prod": "prisma migrate deploy && npm run start:prod",
    "start:dbpush:debug": "prisma db push && npm run start:debug",
    "lint": "tsc && eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:ci": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:debug": "vitest --inspect-brk --no-file-parallelism",
    "test:e2e": "vitest run --config ./vitest.config.e2e.ts"
  },
  "dependencies": {
    "@logtape/express": "^2.1.3",
    "@logtape/logtape": "^2.1.3",
    "@nestjs/common": "12.0.0-alpha.5",
    "@nestjs/config": "12.0.0-next.0",
    "@nestjs/core": "12.0.0-alpha.5",
    "@nestjs/platform-express": "12.0.0-alpha.5",
    "@nestjs/swagger": "12.0.0-alpha.2",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "dotenv": "^16.4.7",
    "pg": "^8.13.0",
    "prisma": "^7.8.0",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@bratislava/eslint-config-nest": "^0.7.0",
    "@nestjs/cli": "12.0.0-alpha.6",
    "@nestjs/schematics": "12.0.0-alpha.9",
    "@nestjs/testing": "12.0.0-alpha.5",
    "@types/express": "^5.0.0",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.11.0",
    "@types/supertest": "^7.0.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.39.2",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.10"
  }
}
